<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Voz → Libras Pro</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    height:100vh;
    display:flex;
    align-items:center;
    justify-content:flex-start;
    padding-left:70px;
    background: linear-gradient(135deg, #0f172a, #2563eb);
    color:white;
}

/* MIC */
.mic{
    width:150px;
    height:150px;
    border-radius:50%;
    background:#111;
    display:flex;
    align-items:center;
    justify-content:center;
    cursor:pointer;
    transition:0.3s;
    box-shadow:0 0 20px rgba(0,0,0,0.4);
}

.mic.ativo{
    transform:scale(1.08);
    box-shadow:0 0 40px #22c55e;
}

.mic img{
    width:70px;
}

/* STATUS */
#status{
    margin-left:30px;
    font-size:18px;
    opacity:0.9;
}

/* LEGENDA */
#legenda{
    position:fixed;
    bottom:40px;
    left:50%;
    transform:translateX(-50%);
    background:rgba(0,0,0,0.75);
    padding:16px 26px;
    border-radius:16px;
    max-width:80%;
    text-align:center;
    font-size:20px;
    line-height:1.5;
    opacity:0;
    transition:0.3s;
    white-space:pre-line;
    backdrop-filter: blur(10px);
}

#legenda.show{
    opacity:1;
}

/* emoção */
#emotion{
    position:fixed;
    top:20px;
    right:20px;
    padding:10px 15px;
    border-radius:12px;
    background:rgba(0,0,0,0.4);
    font-size:14px;
}

/* VLibras */
[vw], [vw-access-button], .vw-plugin-wrapper{
    pointer-events:auto !important;
}
</style>
</head>

<body>

<div style="display:flex; align-items:center;">
    <div id="mic" class="mic">
        <img src="https://cdn-icons-png.flaticon.com/512/61/61088.png">
    </div>
    <div id="status">Ativar microfone</div>
</div>

<div id="legenda"></div>
<div id="emotion">🙂 neutro</div>

<!-- VLibras -->
<div vw class="enabled">
  <div vw-access-button class="active"></div>
  <div vw-plugin-wrapper>
    <div class="vw-plugin-top-wrapper"></div>
  </div>
</div>

<script src="https://vlibras.gov.br/app/vlibras-plugin.js"></script>

<script>
new window.VLibras.Widget('https://vlibras.gov.br/app');

/* =========================
   SPEECH RECOGNITION
========================= */
const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
const recognition = new SpeechRecognition();

recognition.lang = "pt-BR";
recognition.continuous = true;
recognition.interimResults = true;

let ativo = false;

/* =========================
   FILAS INTELIGENTES
========================= */
let filaVLibras = [];
let executandoVLibras = false;

/* =========================
   ELEMENTOS
========================= */
const mic = document.getElementById("mic");
const status = document.getElementById("status");
const legenda = document.getElementById("legenda");
const emotionBox = document.getElementById("emotion");

/* =========================
   MIC
========================= */
mic.onclick = () => {
    if(!ativo){
        recognition.start();
        ativo = true;
        mic.classList.add("ativo");
        status.innerText = "Desligar microfone";
    } else {
        recognition.stop();
        ativo = false;
        mic.classList.remove("ativo");
        status.innerText = "Ativar microfone";
    }
};

/* =========================
   VOZ → TEXTO
========================= */
recognition.onresult = (event) => {
    let texto = "";

    for(let i = event.resultIndex; i < event.results.length; i++){
        texto += event.results[i][0].transcript;
    }

    texto = texto.trim();
    if(texto){
        processarTexto(texto);
    }
};

/* =========================
   PROCESSAMENTO PRINCIPAL
========================= */
function processarTexto(texto){

    mostrarEmocao(texto);

    mostrarLegenda(texto);

    const palavras = texto.split(" ");

    palavras.forEach((p, i) => {
        filaVLibras.push({
            palavra: p,
            delay: i * 900
        });
    });

    processarFila();
}

/* =========================
   EMOÇÃO SIMPLES
========================= */
function mostrarEmocao(texto){
    const t = texto.toLowerCase();

    let emo = "🙂 neutro";

    if(t.includes("obrigado") || t.includes("feliz") || t.includes("bom")){
        emo = "😄 positivo";
    }
    if(t.includes("triste") || t.includes("ruim") || t.includes("dor")){
        emo = "😢 negativo";
    }
    if(t.includes("urgente") || t.includes("agora") || t.includes("ajuda")){
        emo = "🚨 urgente";
    }

    emotionBox.innerText = emo;
}

/* =========================
   LEGENDA
========================= */
function mostrarLegenda(texto){
    legenda.innerText = texto;
    legenda.classList.add("show");

    setTimeout(() => {
        legenda.classList.remove("show");
    }, 4000);
}

/* =========================
   FILA VLIBRAS (INTELIGENTE)
========================= */
function processarFila(){

    if(executandoVLibras) return;
    if(filaVLibras.length === 0) return;

    executandoVLibras = true;

    const item = filaVLibras.shift();

    setTimeout(() => {

        const btn = document.querySelector('[vw-access-button]');
        if(btn) btn.click();

        const tempo = 600 + item.palavra.length * 120;

        setTimeout(() => {
            executandoVLibras = false;
            processarFila();
        }, tempo);

    }, item.delay);
}

/* =========================
   REINÍCIO
========================= */
recognition.onend = () => {
    if(ativo){
        setTimeout(() => recognition.start(), 200);
    }
};
</script>

</body>
</html>
